{
  "name": "noteit",
  "version": "1.0.0",
  "description": "NoteIt — cross-platform sticky notes desktop app (Electron + Vue + SQLite)",
  "main": "./out/main/index.js",
  "author": "noteit",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": "26.x"
  },
  "homepage": "https://github.com/your-org/noteit",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/noteit.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "make-assets": "node scripts/make-assets.mjs",
    "pack:dir": "electron-vite build && electron-builder --dir --publish never",
    "build:mac": "electron-vite build && electron-builder --mac --publish never",
    "build:win": "electron-vite build && electron-builder --win --x64 --publish never",
    "build:win-arm": "electron-vite build && electron-builder --win --arm64 --publish never",
    "build:linux": "electron-vite build && electron-builder --linux --publish never",
    "preversion": "npm run lint && npm test",
    "release:patch": "npm version patch -m \"Release %s\" && git push --follow-tags",
    "release:minor": "npm version minor -m \"Release %s\" && git push --follow-tags",
    "release:major": "npm version major -m \"Release %s\" && git push --follow-tags"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@fortawesome/fontawesome-free": "^7.3.0",
    "@tiptap/extension-code-block-lowlight": "^3.27.4",
    "@tiptap/extension-highlight": "^3.27.4",
    "@tiptap/extension-image": "^3.27.4",
    "@tiptap/extension-link": "^3.27.4",
    "@tiptap/extension-placeholder": "^3.27.4",
    "@tiptap/extension-table": "^3.27.4",
    "@tiptap/extension-task-item": "^3.27.4",
    "@tiptap/extension-task-list": "^3.27.4",
    "@tiptap/extension-text-align": "^3.27.4",
    "@tiptap/extension-underline": "^3.27.4",
    "@tiptap/pm": "^3.27.4",
    "@tiptap/starter-kit": "^3.27.4",
    "@tiptap/vue-3": "^3.27.4",
    "better-sqlite3": "^12.11.1",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "lowlight": "^3.3.0",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/ui": "^4.1.10",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "js-yaml": "^4.1.0",
    "prettier": "^3.9.5",
    "sharp": "^0.35.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "vue-eslint-parser": "^10.4.1"
  }
}
